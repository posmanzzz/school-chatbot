# ==============================================
# 本番環境設定ファイル
# このファイルを .env にコピーして値を設定してください
# cp .env.example .env
# ==============================================

# ドメイン名（必須）
DOMAIN=your-domain.com

# OllamaサーバーのURL（必須）
# 例: http://192.168.1.100:11434 または http://ollama.your-server.com:11434
OLLAMA_BASE_URL=http://your-ollama-server:11434

# Let's Encrypt用メールアドレス（SSL証明書通知用）
LETSENCRYPT_EMAIL=your-email@example.com
